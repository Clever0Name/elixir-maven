---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
}

const {
  title,
  description = 'Elixir Maven — browse 76 classic and modern cocktail recipes with ingredients, methods, glassware and garnish guides.',
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteName = 'Elixir Maven';
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=IBM+Plex+Mono:wght@400;500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="site-nav">
      <div class="container">
        <a href="/" class="site-logo">{siteName}</a>
        <div class="nav-links">
          <a href="/">Cocktails</a>
          <a href="/glossary">Glossary</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-brand">
          <span class="footer-logo">{siteName}</span>
          <span class="footer-tagline">Every classic. Every technique. One collection.</span>
        </div>
        <div class="footer-end">
          <a href="#" class="footer-cta">Get the Collection &rarr;</a>
          <span class="footer-copy">&copy; {year} {siteName}</span>
        </div>
      </div>
    </footer>

    <button id="back-to-top" class="back-to-top" aria-label="Back to top">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 15l-6-6-6 6"/>
      </svg>
    </button>

    <script>
      const topBtn = document.getElementById('back-to-top');
      if (topBtn) {
        window.addEventListener('scroll', () => {
          topBtn.classList.toggle('visible', window.scrollY > 420);
        }, { passive: true });
        topBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      }
    </script>
  </body>
</html>
