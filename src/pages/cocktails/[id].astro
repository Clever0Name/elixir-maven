---
import Layout from '../../layouts/Layout.astro';
import cocktailsData from '../../../elixir_maven_cocktails.json';
import { slugify, formatAmount } from '../../utils/helpers';

export async function getStaticPaths() {
  return cocktailsData.cocktails.map((cocktail) => ({
    params: { id: cocktail.id },
    props: { cocktail },
  }));
}

interface Ingredient {
  name: string;
  role: string;
  amount?: number;
  unit?: string;
  spec: string;
  required: boolean;
  note?: string;
  flavour_tags?: string[];
}

interface Props {
  cocktail: {
    id: string;
    name: string;
    family?: string;
    category: string;
    base_spirit?: string;
    spirit_type?: string;
    method: string;
    glassware: string;
    ice?: string;
    garnish?: string;
    notes?: string;
    description?: string;
    method_steps?: string[];
    ingredients: Ingredient[];
  };
}

const { cocktail } = Astro.props;

function displayIngName(name: string): string {
  return name === 'Double Cream' ? 'Thick|Double Cream' : name;
}

// ─── Proportions bar ────────────────────────────────────────────
const POUR_COLORS = [
  '#E6B73D', '#b08840', '#9b7035', '#8a6230',
  '#7a5428', '#6d5228', '#5e4a28', '#4d3e25',
  '#3f3a2c', '#F2C75B',
];

const mlIngredients = cocktail.ingredients.filter(
  (ing) =>
    ing.unit === 'ml' &&
    typeof ing.amount === 'number' &&
    ing.role !== 'Side Serve' &&
    ing.role !== 'Rinse' &&
    ing.role !== 'Garnish',
);
const totalMl = mlIngredients.reduce((sum, ing) => sum + (ing.amount ?? 0), 0);

// ─── Side serves ────────────────────────────────────────────────
const sideServes = cocktail.ingredients.filter((ing) => ing.role === 'Side Serve');

// ─── Ice display ────────────────────────────────────────────────
const ice = cocktail.ice ?? 'None';

// ─── Notes for Full Serve view ──────────────────────────────────
const sideServeNotes = sideServes.map((s) => s.note).filter(Boolean);
const showCocktailNote =
  !!cocktail.notes && !sideServeNotes.includes(cocktail.notes);
const isVariantNote =
  showCocktailNote &&
  (/^[A-Z][^.!?]+:/.test(cocktail.notes ?? '') ||
    /\bWith\s+[A-Z]/.test(cocktail.notes ?? ''));

function methodGlossaryUrl(method: string): string | null {
  const m = method.toLowerCase();
  if (m.includes('dry shake')) return '/glossary#dry-shake';
  if (m.startsWith('stir') && m.includes('double strain')) return '/glossary#stir-double-strain';
  if (m.startsWith('stir') && m.includes('strain')) return '/glossary#stir-strain';
  if (m.startsWith('stir')) return '/glossary#stir';
  if (m.includes('double strain')) return '/glossary#shake-double-strain';
  if (m.includes('shake') && m.includes('strain')) return '/glossary#shake-strain';
  if (m.includes('muddle')) return '/glossary#muddle';
  if (m.includes('churn')) return '/glossary#churn';
  if (m.startsWith('build')) return '/glossary#build';
  return null;
}

const methodUrl = methodGlossaryUrl(cocktail.method);

const title = `${cocktail.name} Recipe — Elixir Maven`;
const description = `${cocktail.name} — ${cocktail.family ?? cocktail.category}. ${cocktail.method} in a ${cocktail.glassware}. Full recipe with ingredients and measures.`;
---

<Layout title={title} description={description}>
  <div class="container">
    <a href="/" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 5l-7 7 7 7" />
      </svg>
      All Cocktails
    </a>

    <article id="cocktail-page" data-view="spec">

      <!-- ─── Header ─────────────────────────────────── -->
      <header class="page-header">
        <div class="eyebrow-row">
          <span class="eyebrow">{cocktail.family ?? cocktail.category} · {cocktail.category}</span>
          <div class="view-toggle" role="group" aria-label="View mode">
            <button class="toggle-btn" data-mode="spec" aria-pressed="true">Spec</button>
            <span class="toggle-sep" aria-hidden="true">|</span>
            <button class="toggle-btn" data-mode="full" aria-pressed="false">Full Serve</button>
          </div>
          <div class="unit-toggle" role="group" aria-label="Measurement units">
            <button class="toggle-btn unit-btn active" data-unit="ml" aria-pressed="true">ml</button>
            <span class="toggle-sep" aria-hidden="true">|</span>
            <button class="toggle-btn unit-btn" data-unit="oz" aria-pressed="false">oz</button>
          </div>
        </div>
        <h1>{cocktail.name}</h1>
        {cocktail.description && <p class="cocktail-description">{cocktail.description}</p>}
      </header>

      <!-- ══════════════════════════════════════════════
           SPEC VIEW  (compact default)
      ══════════════════════════════════════════════ -->
      <div class="view-spec">
        <div class="recipe-grid">

          <section class="recipe-section" aria-labelledby="ing-heading">
            <h2 class="recipe-section-title" id="ing-heading">Ingredients</h2>
            <ul class="ingredients-list">
              {cocktail.ingredients.map((ing) => (
                <li class="ingredient-row">
                  <div>
                    <div class="ingredient-name">
                      <a href={`/ingredients/${slugify(ing.name)}`}>{displayIngName(ing.name)}</a>
                    </div>
                  </div>
                  <span class="ingredient-amount" data-ml={ing.unit === 'ml' && ing.amount != null ? ing.amount : undefined}>{formatAmount(ing.amount, ing.unit)}</span>
                </li>
              ))}
            </ul>
          </section>

          <section class="recipe-section" aria-labelledby="spec-heading">
            <h2 class="recipe-section-title" id="spec-heading">Spec</h2>
            <div class="spec-grid">
              <div class="spec-row">
                <span class="spec-label">Method</span>
                <span class="spec-value">
                  {methodUrl
                    ? <a href={methodUrl} class="method-link">{cocktail.method}</a>
                    : cocktail.method}
                </span>
              </div>
              <div class="spec-row">
                <span class="spec-label">Glass</span>
                <span class="spec-value">{cocktail.glassware}</span>
              </div>
              <div class="spec-row">
                <span class="spec-label">Ice</span>
                <span class="spec-value">{ice}</span>
              </div>
              {cocktail.garnish && cocktail.garnish !== 'None' && (
                <div class="spec-row">
                  <span class="spec-label">Garnish</span>
                  <span class="spec-value">{cocktail.garnish}</span>
                </div>
              )}
              {cocktail.base_spirit && (
                <div class="spec-row">
                  <span class="spec-label">Base Spirit</span>
                  <span class="spec-value">{cocktail.base_spirit}</span>
                </div>
              )}
            </div>
            {cocktail.notes && (
              <div class="notes-box">
                <strong>Note</strong>
                {cocktail.notes}
              </div>
            )}
            {cocktail.method_steps && cocktail.method_steps.length > 0 && (
              <div class="notes-box">
                <strong>Method</strong>
                <ol class="spec-steps-list">
                  {cocktail.method_steps.map((step) => (
                    <li>{step}</li>
                  ))}
                </ol>
              </div>
            )}
          </section>

        </div>
      </div>

      <!-- ══════════════════════════════════════════════
           FULL SERVE VIEW
      ══════════════════════════════════════════════ -->
      <div class="view-full">

        <!-- Spec heading -->
        <div class="fs-spec-head">
          <h2>Cocktail Specification</h2>
          <small>1 serve</small>
        </div>

        <!-- Ingredient rows with dotted leaders -->
        {cocktail.ingredients.map((ing) => (
          <div class={`fs-row${ing.role === 'Side Serve' ? ' side' : ''}${ing.role === 'Rinse' ? ' rinse' : ''}`}>
            <span class="fs-name">
              <a href={`/ingredients/${slugify(ing.name)}`}>{displayIngName(ing.name)}</a>
            </span>
            <span class="fs-leader" aria-hidden="true"></span>
            <span class="fs-amt" data-ml={ing.unit === 'ml' && ing.amount != null ? ing.amount : undefined}>{formatAmount(ing.amount, ing.unit)}</span>
          </div>
        ))}

        <!-- Build Proportions bar (ml ingredients only, ≥ 2 items) -->
        {mlIngredients.length >= 2 && (
          <div class="fs-pour">
            <div class="fs-pour-label">Build Proportions</div>
            <div class="fs-pour-bar" role="img" aria-label="Build proportions bar">
              {mlIngredients.map((ing, i) => (
                <i
                  style={`width:${(((ing.amount ?? 0) / totalMl) * 100).toFixed(1)}%;background:${POUR_COLORS[i % POUR_COLORS.length]}`}
                  title={`${displayIngName(ing.name)}: ${ing.amount}ml`}
                />
              ))}
            </div>
            <div class="fs-pour-key">
              {mlIngredients.map((ing, i) => (
                <span>
                  <b style={`background:${POUR_COLORS[i % POUR_COLORS.length]}`}></b>
                  {displayIngName(ing.name)}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Service grid -->
        <div class="fs-service">
          <div class="fs-cell">
            <small>Method</small>
            <div class="fs-cell-value">
              {methodUrl
                ? <a href={methodUrl} class="method-link">{cocktail.method}</a>
                : cocktail.method}
            </div>
          </div>
          <div class="fs-cell">
            <small>Ice</small>
            <div class="fs-cell-value">{ice}</div>
          </div>
          <div class="fs-cell">
            <small>Glass</small>
            <div class="fs-cell-value">{cocktail.glassware}</div>
          </div>
          <div class="fs-cell">
            <small>Garnish</small>
            <div class="fs-cell-value">
              {cocktail.garnish && cocktail.garnish !== 'None' ? cocktail.garnish : '—'}
            </div>
          </div>
        </div>

        <!-- Side serve callout -->
        {sideServes.map((ing) => (
          <div class="fs-note">
            <b>Side Serve:</b> {formatAmount(ing.amount, ing.unit)}{' '}
            {displayIngName(ing.name)} on the side.
          </div>
        ))}

        <!-- Cocktail note / variant callout -->
        {showCocktailNote && (
          <div class={`fs-note${isVariantNote ? ' variant' : ''}`}>
            <b>{isVariantNote ? 'Variant:' : 'Note:'}</b> {cocktail.notes}
          </div>
        )}

        <!-- Method steps -->
        {cocktail.method_steps && cocktail.method_steps.length > 0 && (
          <div class="fs-method-steps">
            <div class="fs-method-steps-label">Method</div>
            <ol class="fs-steps-list">
              {cocktail.method_steps.map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          </div>
        )}

      </div>
    </article>
  </div>
</Layout>

<script>
  const STORAGE_KEY = 'elixir-view-mode';
  const UNIT_KEY    = 'elixir-unit';

  const page     = document.getElementById('cocktail-page') as HTMLElement | null;
  const btns     = document.querySelectorAll<HTMLButtonElement>('.view-toggle .toggle-btn');
  const unitBtns = document.querySelectorAll<HTMLButtonElement>('.unit-btn');

  // ─── View mode ──────────────────────────────────────────────────
  function setMode(mode: string) {
    if (!page) return;
    page.dataset.view = mode;
    btns.forEach((btn) => {
      const active = btn.dataset.mode === mode;
      btn.classList.toggle('active', active);
      btn.setAttribute('aria-pressed', String(active));
    });
    try { localStorage.setItem(STORAGE_KEY, mode); } catch {}
  }

  let saved: string | null = null;
  try { saved = localStorage.getItem(STORAGE_KEY); } catch {}
  setMode(saved === 'full' ? 'full' : 'spec');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => setMode(btn.dataset.mode ?? 'spec'));
  });

  // ─── Unit toggle (ml ↔ oz) ──────────────────────────────────────
  function toOz(ml: number): string {
    const oz = ml / 29.5735;
    const rounded = Math.round(oz * 4) / 4;
    return (rounded % 1 === 0 ? rounded.toFixed(0) : rounded.toString()) + 'oz';
  }

  function setUnit(unit: string) {
    unitBtns.forEach((btn) => {
      const active = btn.dataset.unit === unit;
      btn.classList.toggle('active', active);
      btn.setAttribute('aria-pressed', String(active));
    });
    document.querySelectorAll<HTMLElement>('[data-ml]').forEach((el) => {
      const ml = parseFloat(el.dataset.ml ?? '');
      if (isNaN(ml)) return;
      el.textContent = unit === 'oz' ? toOz(ml) : ml + 'ml';
    });
    try { localStorage.setItem(UNIT_KEY, unit); } catch {}
  }

  let savedUnit: string | null = null;
  try { savedUnit = localStorage.getItem(UNIT_KEY); } catch {}
  setUnit(savedUnit === 'oz' ? 'oz' : 'ml');

  unitBtns.forEach((btn) => {
    btn.addEventListener('click', () => setUnit(btn.dataset.unit ?? 'ml'));
  });
</script>
