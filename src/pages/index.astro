---
import Layout from '../layouts/Layout.astro';
import CocktailCard from '../components/CocktailCard.astro';
import cocktailsData from '../../elixir_maven_cocktails.json';

const cocktails = cocktailsData.cocktails;

const categories = [...new Set(cocktails.map((c) => c.category))].sort();
const TASTE_FILTERS = ['Sour', 'Bitter', 'Smooth', 'Sharp', 'Sweet', 'Delight'];

const totalCount = cocktails.length;
---

<Layout
  title="Elixir Maven — Cocktail Finder"
  description={`Browse ${totalCount} classic and modern cocktail recipes. Search by name, filter by base spirit, and find full recipes with ingredients, method and glassware.`}
>
  <div class="container">
    <!-- Hero -->
    <section class="hero">
      <h1>Elixir Maven</h1>
      <p class="hero-sub">
        <span id="hero-count" data-target={totalCount}>0</span> cocktail recipes &mdash; the complete collection
      </p>

      <div class="search-wrap">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <input
          id="search"
          class="search-input"
          type="search"
          placeholder="Search cocktails or ingredients&hellip;"
          aria-label="Search cocktails"
          autocomplete="off"
        />
      </div>

      <div class="filter-row" role="group" aria-label="Filter by spirit">
        <button class="filter-btn active" data-filter="all">All</button>
        {categories.map((cat) => <button class="filter-btn" data-filter={cat}>{cat}</button>)}
      </div>

      <div class="filter-row taste-filter-row" role="group" aria-label="Filter by taste">
        <span class="taste-row-label">Taste</span>
        {TASTE_FILTERS.map((taste) => (
          <button class={`taste-tag taste-filter-btn tag-${taste.toLowerCase()}`} data-taste={taste}>{taste}</button>
        ))}
      </div>

      <div class="hero-actions">
        <button id="surprise-me" class="surprise-btn" aria-label="Go to a random cocktail">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/>
            <polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/>
          </svg>
          Surprise Me
        </button>
      </div>
    </section>

    <!-- Volumes banner -->
    <div class="volumes-banner">
      <p class="volumes-headline">Take Elixir Maven with you</p>
      <div class="volumes-grid">
        <a href="#" class="volume-card">Volume I</a>
        <a href="#" class="volume-card">Volume II</a>
        <a href="#" class="volume-card">Volume III</a>
        <a href="#" class="volume-card">Volume IV</a>
      </div>
    </div>

    <!-- View controls -->
    <div class="view-controls" aria-label="View options">
      <div class="control-group">
        <span class="control-label">Group by</span>
        <div class="sq-toggle" role="group" aria-label="Group by">
          <button class="sq-btn group-btn active" data-group="none">None</button>
          <button class="sq-btn group-btn" data-group="taste">Taste</button>
        </div>
      </div>
    </div>

    <p class="results-count" id="results-count" aria-live="polite"></p>

    <div class="cocktail-grid" id="cocktail-grid">
      {cocktails.map((cocktail) => <CocktailCard cocktail={cocktail} />)}
      <div class="no-results" id="no-results" style="display:none">
        <h3>No cocktails found</h3>
        <p>Try a different search or filter.</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  // ─── Animated counter ───────────────────────────────────────────
  const heroCount = document.getElementById('hero-count') as HTMLElement | null;
  if (heroCount) {
    const target = parseInt(heroCount.dataset.target ?? '0', 10);
    const duration = 3600;
    const start = performance.now();
    const tick = (now: number) => {
      const t = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - t, 3);
      heroCount.textContent = String(Math.round(ease * target));
      if (t < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  // ─── Surprise Me ────────────────────────────────────────────────
  const surpriseBtn = document.getElementById('surprise-me');
  if (surpriseBtn) {
    surpriseBtn.addEventListener('click', () => {
      const hrefs = [...document.querySelectorAll<HTMLAnchorElement>('.cocktail-card')]
        .map((c) => c.getAttribute('href'))
        .filter(Boolean) as string[];
      if (hrefs.length) window.location.href = hrefs[Math.floor(Math.random() * hrefs.length)];
    });
  }

  const GROUP_KEY = 'elixir-group';
  const TASTE_ORDER = ['Sour', 'Bitter', 'Smooth', 'Sharp', 'Sweet', 'Delight'];

  const searchInput = document.getElementById('search') as HTMLInputElement;
  const filterBtns  = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const tasteBtns   = document.querySelectorAll<HTMLButtonElement>('.taste-filter-btn');
  const groupBtns   = document.querySelectorAll<HTMLButtonElement>('.group-btn');
  const grid        = document.getElementById('cocktail-grid') as HTMLElement;
  const cards       = document.querySelectorAll<HTMLAnchorElement>('.cocktail-card');
  const countEl     = document.getElementById('results-count');
  const noResults   = document.getElementById('no-results') as HTMLElement;

  let activeFilter = 'all';
  let activeTaste  = 'all';
  let activeGroup  = 'none';

  const originalOrder = [...cards];

  function setGroup(group: string) {
    activeGroup = group;
    groupBtns.forEach((btn) => btn.classList.toggle('active', btn.dataset.group === group));
    try { localStorage.setItem(GROUP_KEY, group); } catch {}
    updateDisplay();
  }

  function updateDisplay() {
    const query = searchInput?.value.toLowerCase().trim() ?? '';
    let visible = 0;

    // Remove any existing group headers
    grid.querySelectorAll('.taste-group-header').forEach((h) => h.remove());

    // Restore original card order before re-grouping
    originalOrder.forEach((card) => grid.insertBefore(card, noResults));

    const visibleCards: HTMLAnchorElement[] = [];

    cards.forEach((card) => {
      const name        = card.dataset.name ?? '';
      const category    = card.dataset.category ?? '';
      const ingredients = card.dataset.ingredients ?? '';
      const taste       = card.dataset.taste ?? '';

      const matchesSearch = !query || name.includes(query) || ingredients.includes(query);
      const matchesFilter = activeFilter === 'all' || category === activeFilter;
      const matchesTaste  = activeTaste === 'all' || taste === activeTaste;

      if (matchesSearch && matchesFilter && matchesTaste) {
        card.style.display = '';
        visible++;
        visibleCards.push(card);
      } else {
        card.style.display = 'none';
      }
    });

    if (activeGroup === 'taste') {
      const sorted = [...visibleCards].sort((a, b) => {
        const ta = TASTE_ORDER.indexOf(a.dataset.taste ?? '');
        const tb = TASTE_ORDER.indexOf(b.dataset.taste ?? '');
        return ta - tb;
      });

      let lastTaste = '';
      sorted.forEach((card) => {
        const taste = card.dataset.taste ?? '';
        if (taste !== lastTaste) {
          const header = document.createElement('div');
          header.className = 'taste-group-header';
          header.textContent = taste;
          grid.insertBefore(header, noResults);
          lastTaste = taste;
        }
        grid.insertBefore(card, noResults);
      });
    }

    if (countEl)   countEl.textContent = `${visible} cocktail${visible !== 1 ? 's' : ''}`;
    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  let savedGroup: string | null = null;
  try { savedGroup = localStorage.getItem(GROUP_KEY); } catch {}

  setGroup(savedGroup === 'taste' ? 'taste' : 'none');

  searchInput?.addEventListener('input', updateDisplay);

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = btn.dataset.filter ?? 'all';
      updateDisplay();
    });
  });

  tasteBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.taste ?? '';
      if (activeTaste === selected) {
        activeTaste = 'all';
        tasteBtns.forEach((b) => b.classList.remove('active'));
      } else {
        activeTaste = selected;
        tasteBtns.forEach((b) => b.classList.toggle('active', b.dataset.taste === selected));
      }
      updateDisplay();
    });
  });

  groupBtns.forEach((btn) => {
    btn.addEventListener('click', () => setGroup(btn.dataset.group ?? 'none'));
  });
</script>
