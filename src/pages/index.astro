---
import Layout from '../layouts/Layout.astro';
import CocktailCard from '../components/CocktailCard.astro';
import cocktailsData from '../../elixir_maven_cocktails.json';

const cocktails = cocktailsData.cocktails;

// Unique categories for filter chips
const categories = [...new Set(cocktails.map((c) => c.category))].sort();

const totalCount = cocktails.length;
---

<Layout
  title="Elixir Maven — Cocktail Finder"
  description={`Browse ${totalCount} classic and modern cocktail recipes. Search by name, filter by base spirit, and find full recipes with ingredients, method and glassware.`}
>
  <div class="container">
    <!-- Hero -->
    <section class="hero">
      <h1>Elixir Maven</h1>
      <p class="hero-sub">{totalCount} cocktail recipes &mdash; the complete collection</p>

      <div class="search-wrap">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <input
          id="search"
          class="search-input"
          type="search"
          placeholder="Search cocktails or ingredients&hellip;"
          aria-label="Search cocktails"
          autocomplete="off"
        />
      </div>

      <div class="filter-row" role="group" aria-label="Filter by spirit">
        <button class="filter-btn active" data-filter="all">All</button>
        {categories.map((cat) => <button class="filter-btn" data-filter={cat}>{cat}</button>)}
      </div>
    </section>

    <p class="results-count" id="results-count" aria-live="polite"></p>

    <div class="cocktail-grid" id="cocktail-grid">
      {cocktails.map((cocktail) => <CocktailCard cocktail={cocktail} />)}
      <div class="no-results" id="no-results" style="display:none">
        <h3>No cocktails found</h3>
        <p>Try a different search or filter.</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLAnchorElement>('.cocktail-card');
  const countEl = document.getElementById('results-count');
  const noResults = document.getElementById('no-results');

  let activeFilter = 'all';

  function updateDisplay() {
    const query = searchInput.value.toLowerCase().trim();
    let visible = 0;

    cards.forEach((card) => {
      const name = card.dataset.name ?? '';
      const category = card.dataset.category ?? '';
      const ingredients = card.dataset.ingredients ?? '';

      const matchesSearch =
        !query || name.includes(query) || ingredients.includes(query);
      const matchesFilter = activeFilter === 'all' || category === activeFilter;

      if (matchesSearch && matchesFilter) {
        card.style.display = '';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });

    if (countEl) {
      countEl.textContent = `${visible} cocktail${visible !== 1 ? 's' : ''}`;
    }
    if (noResults) {
      noResults.style.display = visible === 0 ? 'block' : 'none';
    }
  }

  searchInput?.addEventListener('input', updateDisplay);

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = btn.dataset.filter ?? 'all';
      updateDisplay();
    });
  });

  updateDisplay();
</script>
